rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - nickname: string (required, unique)
    //   - email: string (required)
    //   - role: string (required, enum: ['admin', 'moderator', 'user'])
    //   - createdAt: timestamp (required)
    //
    // Collection: nicknames
    // Document ID: {nickname}
    // Fields:
    //   - uid: string (required)
    //
    // Collection: promocodes
    // Document ID: {code}
    // Fields:
    //   - code: string (required)
    //   - expiresAt: timestamp (required)
    //   - maxAttempts: number (required)
    //   - createdBy: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "minerpc2002@gmail.com")
      );
    }

    function isModerator() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator') ||
        isAdmin()
      );
    }

    function isStaff() {
      return isAdmin() || isModerator();
    }

    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'nickname', 'email', 'role', 'createdAt']) &&
             data.uid == userId &&
             data.nickname is string && data.nickname.size() >= 3 && data.nickname.size() <= 20 &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['admin', 'moderator', 'user'] &&
             data.createdAt is number &&
             (!('activePromoCode' in data) || data.activePromoCode == null || (
               data.activePromoCode.keys().hasAll(['code', 'expiresAt', 'maxAttempts', 'createdBy', 'createdAt']) &&
               data.activePromoCode.code is string &&
               data.activePromoCode.expiresAt is number &&
               data.activePromoCode.maxAttempts is number &&
               data.activePromoCode.createdBy is string &&
               data.activePromoCode.createdAt is number
             ));
    }

    function isValidPromoCode(data) {
      return data.keys().hasAll(['code', 'expiresAt', 'maxAttempts', 'createdBy', 'createdAt']) &&
             data.code is string && data.code.size() >= 1 && data.code.size() <= 20 &&
             data.expiresAt is number &&
             data.maxAttempts is number && data.maxAttempts > 0 &&
             data.createdBy == request.auth.uid &&
             data.createdAt is number;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data, userId) && 
                    (request.resource.data.role == 'user' || (request.resource.data.role == 'admin' && request.auth.token.email != null && request.auth.token.email.lower() == "minerpc2002@gmail.com" && request.auth.token.email_verified == true)) && 
                    (!('activePromoCode' in request.resource.data) || request.resource.data.activePromoCode == null || (
                      get(/databases/$(database)/documents/promocodes/$(request.resource.data.activePromoCode.code)).data.expiresAt > request.time.toMillis()
                    ));
      allow update: if isAuthenticated() && (
        (isOwner(userId) && 
         request.resource.data.role == resource.data.role && 
         (!('activePromoCode' in request.resource.data) || 
          request.resource.data.activePromoCode == null || 
          ('activePromoCode' in resource.data && request.resource.data.activePromoCode == resource.data.activePromoCode) ||
          get(/databases/$(database)/documents/promocodes/$(request.resource.data.activePromoCode.code)).data.expiresAt > request.time.toMillis()
         ) &&
         isValidUser(request.resource.data, userId)) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /nicknames/{nickname} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && nickname.size() >= 3 && nickname.size() <= 20;
      allow delete: if isAdmin();
    }

    match /promocodes/{code} {
      allow read: if isAuthenticated();
      allow create: if isStaff() && isValidPromoCode(request.resource.data);
      allow update: if isStaff() && isValidPromoCode(request.resource.data);
      allow delete: if isAdmin();
    }

    match /user_logs/{logId} {
      allow read: if isStaff();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.keys().hasAll(['userId', 'action', 'timestamp']);
      allow update, delete: if false;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /support_messages/{messageId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (
        (request.resource.data.userId == request.auth.uid && request.resource.data.senderId == request.auth.uid && request.resource.data.isAdmin == false) ||
        (isStaff() && request.resource.data.senderId == request.auth.uid && request.resource.data.isAdmin == true)
      ) && request.resource.data.keys().hasAll(['userId', 'senderId', 'text', 'isAdmin', 'timestamp']) &&
      request.resource.data.text is string && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 1000;
      allow update: if false;
      allow delete: if isStaff();
    }

    match /support_chats/{userId} {
      allow read: if isStaff() || isOwner(userId);
      allow write: if isStaff() || isOwner(userId);
    }
  }
}
